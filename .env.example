# Lesarge Workforce Hub — Environment Configuration Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control

# ========== DATABASE CONFIGURATION ==========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lesarge_workforce_hub
DB_USER=root
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# ========== WORDPRESS CONFIGURATION ==========
WP_ENV=local
WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false

# ========== SITE URLS ==========
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080

# ========== SECURITY KEYS & SALTS ==========
# Generate unique values from: https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY=put_your_unique_phrase_here
SECURE_AUTH_KEY=put_your_unique_phrase_here
LOGGED_IN_KEY=put_your_unique_phrase_here
NONCE_KEY=put_your_unique_phrase_here
AUTH_SALT=put_your_unique_phrase_here
SECURE_AUTH_SALT=put_your_unique_phrase_here
LOGGED_IN_SALT=put_your_unique_phrase_here
NONCE_SALT=put_your_unique_phrase_here

# ========== MULTISITE CONFIGURATION (Optional) ==========
WP_ALLOW_MULTISITE=false
MULTISITE=false
SUBDOMAIN_INSTALL=true

# ========== PERFORMANCE ==========
WP_CACHE=false

# ========== EMAIL CONFIGURATION (Optional) ==========
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@lesarge.local
